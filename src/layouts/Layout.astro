---
const { title } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <div class="app-shell">
      <aside class="sidebar">
        <a class="brand" href="/">Portfolio</a>
        <p class="sidebar-summary">Enterprise SI / Full-stack Developer</p>
        <nav>
          <a href="/">Main</a>
          <a href="/experience/">Experience</a>
        </nav>
      </aside>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
