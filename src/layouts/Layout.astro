---
const { title, description = "금융·보험 도메인 중심 10년차 풀스택 개발자 민순홍의 포트폴리오", image, ogType = "website", mainClass } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const siteUrl = "https://ruymin.github.io/portfolio";
const ogImage = image || `${siteUrl}/images/og-cover.png`;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:site_name" content="민순홍 포트폴리오" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="stylesheet" href={`${base}styles/global.css`} />
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar">
        <a class="brand" href={base}>MinSoonHong</a>
        <nav class="top-nav" id="top-nav" aria-label="Primary navigation">
          <a href={`${base}#hero`} data-section-link="hero">Profile</a>
          <a href={`${base}#experience`} data-section-link="experience">Experience</a>
          <a href={`${base}#skills`} data-section-link="skills">Skills</a>
          <a href={`${base}#projects`} data-section-link="projects">Projects</a>
          <a href={`${base}#side-projects`} data-section-link="side-projects">Side Projects</a>
        </nav>
        <div class="topbar-actions">
          <button class="theme-toggle" type="button" aria-label="Toggle theme">THEME</button>
          <button class="menu-toggle" type="button" aria-label="Toggle menu" aria-expanded="false" aria-controls="top-nav">
            <svg class="icon-menu" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <line x1="3" y1="6" x2="21" y2="6"/>
              <line x1="3" y1="12" x2="21" y2="12"/>
              <line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
            <svg class="icon-close" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <line x1="6" y1="6" x2="18" y2="18"/>
              <line x1="6" y1="18" x2="18" y2="6"/>
            </svg>
          </button>
        </div>
      </header>
      <main class={mainClass}>
        <slot />
      </main>
    </div>
    <script>
      const root = document.documentElement;
      const storedTheme = localStorage.getItem("theme");
      if (storedTheme === "light") {
        root.classList.add("light");
      }

      document.querySelector(".theme-toggle")?.addEventListener("click", () => {
        root.classList.toggle("light");
        localStorage.setItem("theme", root.classList.contains("light") ? "light" : "dark");
      });

      // Mobile menu toggle
      const menuToggle = document.querySelector(".menu-toggle");
      const topNav = document.getElementById("top-nav");
      if (menuToggle && topNav) {
        menuToggle.addEventListener("click", () => {
          const isOpen = topNav.classList.toggle("is-open");
          menuToggle.setAttribute("aria-expanded", String(isOpen));
        });
        // Close menu when a nav link is clicked
        topNav.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", () => {
            topNav.classList.remove("is-open");
            menuToggle.setAttribute("aria-expanded", "false");
          });
        });
      }

      const links = Array.from(document.querySelectorAll("[data-section-link]"));
      const sections = links
        .map((link) => {
          const id = link.getAttribute("data-section-link");
          return id ? document.getElementById(id) : null;
        })
        .filter(Boolean);

      const setActive = (id) => {
        links.forEach((link) => {
          link.classList.toggle("is-active", link.getAttribute("data-section-link") === id);
        });
      };

      if (sections.length > 0) {
        const updateActiveAtBottom = () => {
          const bottomReached =
            window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 4;

          if (bottomReached) {
            setActive("side-projects");
          }
        };

        const observer = new IntersectionObserver(
          (entries) => {
            if (window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 4) {
              setActive("side-projects");
              return;
            }

            const visible = entries
              .filter((entry) => entry.isIntersecting)
              .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

            if (visible?.target?.id) {
              setActive(visible.target.id);
            }
          },
          {
            rootMargin: "-22% 0px -58% 0px",
            threshold: [0.12, 0.24, 0.4, 0.6]
          }
        );

        sections.forEach((section) => observer.observe(section));
        setActive(location.hash ? location.hash.slice(1) : "hero");
        window.addEventListener("scroll", updateActiveAtBottom, { passive: true });
        window.addEventListener("resize", updateActiveAtBottom);
        updateActiveAtBottom();
      }

      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 }
      );

      document.querySelectorAll(".reveal, .glass-card").forEach((element) => {
        element.classList.add("reveal");
        revealObserver.observe(element);
      });
    </script>
  </body>
</html>
