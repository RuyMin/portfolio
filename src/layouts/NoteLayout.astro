---
const { frontmatter } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{frontmatter.title}</title>
    <link rel="stylesheet" href={`${base}styles/global.css`} />
  </head>
  <body>
    <div class="app-shell">
      <aside class="sidebar">
        <a class="brand" href={base}>Portfolio</a>
        <p class="sidebar-summary">Enterprise SI / Full-stack Developer</p>
        <nav>
          <a href={base}>Main</a>
          <a href={`${base}experience/`}>Experience</a>
        </nav>
      </aside>
      <main class="article">
        <p class="eyebrow">{frontmatter.description}</p>
        <h1>{frontmatter.title}</h1>
        <slot />
      </main>
    </div>
  </body>
</html>
