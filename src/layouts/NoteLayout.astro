---
import Layout from "./Layout.astro";
const { frontmatter } = Astro.props;
---

<Layout
  title={frontmatter.title}
  description={frontmatter.description || "민순홍 포트폴리오"}
  ogType="article"
  mainClass="article"
>
  <p class="section-kicker">{frontmatter.description}</p>
  <h1>{frontmatter.title}</h1>
  <slot />
</Layout>
